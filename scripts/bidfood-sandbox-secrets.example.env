# Voorbeeld voor Supabase Edge Function secrets (Bidfood sandbox-test).
# 1. Kopieer naar een lokaal bestand buiten git (bijv. .env.bidfood.sandbox).
# 2. Vul USERNAME/PASSWORD uit het sandbox-PDF van Bidfood.
# 3: supabase secrets set --env-file .env.bidfood.sandbox --project-ref <jouw-project-ref>
#    Let op: wachtwoord met # moet tussen aanhalingstekens, anders wordt alles na # weggeknipt:
#    BIDFOOD_PASSWORD="97#Dpk!(@8"
#    Aanbevolen (geen #-probleem): base64 van het wachtwoord:
#    BIDFOOD_PASSWORD_B64=OTcjRHBrIShAOA==
#    supabase secrets set BIDFOOD_PASSWORD_B64=OTcjRHBrIShAOA== BIDFOOD_USERNAME=...
#
# BIDFOOD_USERNAME=
# BIDFOOD_PASSWORD=
BIDFOOD_USE_SANDBOX=1

# Productie (per klantnummer, voorbeeld Amsterdam):
# BIDFOOD_USERNAME_074380=
# BIDFOOD_PASSWORD_B64_074380=
# BIDFOOD_USERNAME_076970=
# BIDFOOD_PASSWORD_B64_076970=
# BIDFOOD_USERNAME_080840=
# BIDFOOD_PASSWORD_B64_080840=
# Optioneel (defaults = test-PDF):
# BIDFOOD_SANDBOX_BASE_URL=https://bas.staging.bidfood.nl/sandbox
# BIDFOOD_SANDBOX_CUSTOMER=000040
# Niet zetten tenzij Bidfood het vraagt (standaard geeft system-Name 401):
# BIDFOOD_SEND_SYSTEM_NAME=1
# BIDFOOD_SYSTEM_NAME=MIMA
