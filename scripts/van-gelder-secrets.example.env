# Van Gelder APIM — per subscription een eigen primary key (portal → Show).
# Niet committen. Voorbeeld:
#   supabase secrets set --env-file .env.van-gelder.local
#
# OAuth (zelfde voor alle API's; acc/prod-waarden van Van Gelder)
# VAN_GELDER_CLIENT_ID=
# VAN_GELDER_CLIENT_SECRET=
# VAN_GELDER_TOKEN_URL=
# VAN_GELDER_SCOPE=
#
# Omgeving
# VAN_GELDER_API_BASE_URL=https://vg-acc-we-apim.azure-api.net
# VAN_GELDER_ORDER_URL=https://vg-acc-we-apim.azure-api.net/api/orders/2.0/create
# prod: VAN_GELDER_API_BASE_URL=https://vg-prd-we-apim.azure-api.net
# prod: VAN_GELDER_ORDER_URL=https://vg-prd-we-apim.azure-api.net/api/orders/2.0/create
#
# Subscription keys (één per product in het portaal)
# VAN_GELDER_SUBSCRIPTION_KEY_ORDERS=
# VAN_GELDER_SUBSCRIPTION_KEY_ARTICLES=
# VAN_GELDER_SUBSCRIPTION_KEY_ASSORTMENTS=
# VAN_GELDER_SUBSCRIPTION_KEY_CUSTOMER=
# VAN_GELDER_SUBSCRIPTION_KEY_PRICES=
#
# Legacy alias voor orders (optioneel)
# VAN_GELDER_SUBSCRIPTION_KEY=
