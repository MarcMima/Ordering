# Supabase (create a project at https://supabase.com and copy these values)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Auth: in Supabase Dashboard → Authentication → Providers → Email: enable Email.
# Create users under Authentication → Users, or enable "Sign up" if you want open registration.

# Set to true to skip login (open kitchen mode; requires migration 151 anon policies).
# NEXT_PUBLIC_AUTH_DISABLED=true
