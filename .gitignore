# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# gegenereerd uit lokale Excel (groot; opnieuw met scripts/mima_xlsx_parse.py)
/scripts/parsed_*.json

# Bidfood sandbox test-PDF bevat API-credentials; niet committen
*Bidfood*Sandbox*.pdf
Testdata Bidfood Sandbox*.pdf

# Van Gelder API probe exports (lokaal)
tmp_vg_*.json

# Grote Excel review exports (lokaal gegenereerd)
exports_*_match_review*.xlsx
docs/*-export.xlsx
docs/*-overzicht.xlsx
docs/*-mapping-review.xlsx
docs/gede-jph-mapping.xlsx
docs/van-gelder-variants-bestellijst.xlsx
